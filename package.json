{
  "name": "roms-restaurant-system",
  "productName": "Restaurant Order Management System",
  "private": true,
  "version": "1.0.2",
  "description": "Restaurant Order Management System - Professional Desktop Edition",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "start": "node server.ts",
    "electron:dev": "electron .",
    "build:server": "node build-server.mjs",
    "build:all": "npm run build && npm run build:server",
    "electron:build": "npm run build:all && electron-builder --win --x64",
    "electron:build:kitchen": "electron-builder --win --x64 -c.extraMetadata.main=electron/kitchen.cjs -c.productName=\"Kitchen Panel\" -c.publish.channel=kitchen",
    "dist": "npm run electron:build"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@types/multer": "^2.1.0",
    "@vitejs/plugin-react": "^5.0.4",
    "axios": "^1.14.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.8.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.8.3",
    "express": "^4.21.2",
    "firebase": "^12.11.0",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^2.5.1",
    "jspdf-autotable": "^3.8.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.13.2",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "vite": "^6.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^33.4.11",
    "electron-builder": "^24.13.3",
    "esbuild": "^0.24.2",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  },
  "build": {
    "appId": "com.roms.restaurant",
    "productName": "Restaurant Order Management System",
    "publish": [
      {
        "provider": "github",
        "owner": "safwantnd1-a11y",
        "repo": "restaurant-order-management-system"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "server.cjs",
      "node_modules/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "server.cjs",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*",
      "node_modules/prebuild-install/**/*",
      "dist/**/*"
    ],
    "extraResources": [
      {
        "from": "roms.db",
        "to": "roms.db"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ROMS Restaurant"
    }
  }
}
